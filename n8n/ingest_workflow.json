      {
        "parameters": {
          "jsCode": "return $input.all().map((item) => {\n  const row = item.json;\n  const bin = String(row['БИН'] ?? '').trim();\n  const name = String(row['Название'] ?? '').trim();\n  const city = String(row['Город'] ?? '').trim();\n  const activity = String(row['Вид деятельности'] ?? '').trim();\n  const status = String(row['Статус'] ?? '').trim();\n  const registrationDate = String(row['Дата регистрации'] ?? '').trim();\n\n  return {\n    json: {\n      pageContent: `БИН: ${bin}\\nНазвание: ${name}\\nГород: ${city}\\nВид деятельности: ${activity}\\nСтатус: ${status}\\nДата регистрации: ${registrationDate}`,\n      bin,\n      name,\n      city,\n      activity,\n      status,\n      registration_date: registrationDate\n    }\n  };\n});"
        },
