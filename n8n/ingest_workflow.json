        "name": "Format Payload",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          608,
          0
        ]
      },
      {
        "parameters": {
          "options": {
            "pointers": "/pageContent",
            "metadata": {
              "metadataValues": [
                {
                  "name": "bin",
                  "value": "={{ $json.bin }}"
                },
                {
